# Copy this file to .env and edit values as needed. .env is gitignored.

# Used to sign session cookies. Any non-empty string works in dev.
SECRET_KEY=dev-secret-change-me

# Port the Flask server listens on.
PORT=5000

# Default seconds between auto-called words (host can override per game).
DEFAULT_CALL_INTERVAL_SECONDS=5

# LLM provider keys. The llm_client picks whichever is set, in this order:
# GEMINI_API_KEY first, then ANTHROPIC_API_KEY, then OPENAI_API_KEY.
# Only Gemini is wired up in iteration 2; the others raise NotImplementedError.
# Leave blank to disable the AI features (game still works without them).
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Email / OTP authentication (project-enhancement branch)
# Create a Google App Password at: myaccount.google.com > Security > App Passwords
# If left blank, OTP codes are printed to the server console instead of emailed
# (useful for local demo without a real Gmail account).
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# How long OTP codes stay valid (default 10 minutes).
OTP_EXPIRY_MINUTES=10
# Email domain allowed to join games. Only @cgi.com emails are accepted by default.
CGI_EMAIL_DOMAIN=cgi.com
