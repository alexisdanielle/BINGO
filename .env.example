# Copy this file to .env and edit values as needed. .env is gitignored.

# Used to sign session cookies. Any non-empty string works in dev.
SECRET_KEY=dev-secret-change-me

# Port the Flask server listens on.
PORT=5000

# Default seconds between auto-called words (host can override per game).
DEFAULT_CALL_INTERVAL_SECONDS=5

# Optional. Only the AI announcement layer reads this. Leave blank to disable.
ANTHROPIC_API_KEY=
